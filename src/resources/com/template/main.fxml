<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="1000.0" style="-fx-background-color: #0f172a;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.template.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" prefWidth="1000.0" style="-fx-background-color: #1e293b; -fx-border-color: #334155; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="⚽" textFill="#10b981">
                            <font>
                                <Font size="28.0" />
                            </font>
                        </Label>
                        <Label text="Team" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                        <Label text="Manager" textFill="#10b981">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <HBox alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                    <children>
                        <TextField fx:id="txtSearch" prefHeight="40.0" prefWidth="300.0" promptText="🔍 Pesquisar time, cidade ou liga..." style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 0 15 0 15;">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </TextField>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
            <effect>
                <DropShadow blurType="GAUSSIAN" height="15.0" radius="7.0" width="15.0">
                    <color>
                        <Color opacity="0.3" />
                    </color>
                </DropShadow>
            </effect>
        </HBox>
    </top>

    <left>
        <VBox prefWidth="320.0" spacing="20.0" style="-fx-background-color: #1e293b; -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: #334155;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Detalhes do Time" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </Label>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Nome da Equipe" textFill="#9ca3af">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtNome" prefHeight="40.0" promptText="Ex: São Paulo FC" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Cidade" textFill="#9ca3af">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtCidade" prefHeight="40.0" promptText="Ex: São Paulo, SP" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Estádio" textFill="#9ca3af">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtEstadio" prefHeight="40.0" promptText="Ex: MorumBIS" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Liga / Campeonato" textFill="#9ca3af">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>
                        <TextField fx:id="txtLiga" prefHeight="40.0" promptText="Ex: Brasileirão Série A" style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-border-color: #334155; -fx-border-radius: 8; -fx-background-radius: 8;" />
                    </children>
                </VBox>

                <VBox alignment="BOTTOM_CENTER" spacing="12.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button fx:id="btnSave" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 14px;" text="CADASTRAR EQUIPE">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Button fx:id="btnClear" maxWidth="1.7976931348623157E308" mnemonicParsing="false" prefHeight="45.0" style="-fx-background-color: transparent; -fx-text-fill: #9ca3af; -fx-border-color: #475569; -fx-border-radius: 10; -fx-font-weight: bold; -fx-font-size: 14px;" text="LIMPAR CAMPOS">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </children>
                    <padding>
                        <Insets top="20.0" />
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>
            <BorderPane.margin>
                <Insets bottom="20.0" left="20.0" right="10.0" top="20.0" />
            </BorderPane.margin>
            <effect>
                <DropShadow blurType="GAUSSIAN" height="20.0" radius="9.5" width="20.0">
                    <color>
                        <Color opacity="0.25" />
                    </color>
                </DropShadow>
            </effect>
        </VBox>
    </left>

    <!-- ÁREA CENTRAL (TABELA CARD) -->
    <center>
        <VBox prefHeight="200.0" prefWidth="100.0" spacing="15.0" style="-fx-background-color: #1e293b; -fx-background-radius: 16; -fx-border-color: #334155; -fx-border-radius: 16;" BorderPane.alignment="CENTER">
            <children>
                <Label text="Equipes Cadastradas" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>

                <!-- Truque com -fx-base para forçar um tema dark na tabela nativa -->
                <TableView fx:id="tableView" prefHeight="450.0" prefWidth="560.0" style="-fx-base: #1e293b; -fx-control-inner-background: #0f172a; -fx-background-color: transparent; -fx-table-cell-border-color: transparent; -fx-table-header-border-color: #334155; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colNome" prefWidth="160.0" style="-fx-font-weight: bold; -fx-alignment: CENTER-LEFT;" text="Equipe" />
                        <TableColumn fx:id="colCidade" prefWidth="140.0" style="-fx-alignment: CENTER-LEFT;" text="Cidade" />
                        <TableColumn fx:id="colEstadio" prefWidth="150.0" style="-fx-alignment: CENTER-LEFT;" text="Estádio" />
                        <TableColumn fx:id="colLiga" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Liga" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" prefHeight="50.0" spacing="12.0">
                    <children>
                        <Button fx:id="btnUpdate" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" text="✏️ Editar">
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                        <Button fx:id="btnDelete" mnemonicParsing="false" prefHeight="40.0" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold;" text="🗑️ Excluir">
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </HBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <BorderPane.margin>
                <Insets bottom="20.0" left="10.0" right="20.0" top="20.0" />
            </BorderPane.margin>
            <effect>
                <DropShadow blurType="GAUSSIAN" height="20.0" radius="9.5" width="20.0">
                    <color>
                        <Color opacity="0.25" />
                    </color>
                </DropShadow>
            </effect>
        </VBox>
    </center>
</BorderPane>